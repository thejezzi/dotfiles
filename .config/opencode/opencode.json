{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/",
      "enabled": true
    },
    "sonarqube": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "--init",
        "--pull=always",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_URL": "{env:SONARQUBE_URL}"
      },
      "enabled": false
    },
    "mcp-atlassian": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "JIRA_URL",
        "-e",
        "JIRA_USERNAME",
        "-e",
        "JIRA_API_TOKEN",
        "-e",
        "JIRA_PROJECTS_FILTER",
        "-e",
        "READ_ONLY_MODE",
        "-e",
        "MCP_VERBOSE",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "environment": {
        "JIRA_URL": "https://c24-reda.atlassian.net",
        "JIRA_USERNAME": "florian.hauptmann@check24.de",
        "JIRA_API_TOKEN": "{env:JIRA_API_TOKEN}",
        "JIRA_PROJECTS_FILTER": "RSW",
        "READ_ONLY_MODE": "true",
        "MCP_VERBOSE": "true"
      }
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": false
    },
    "context-mode": {
      "type": "local",
      "command": [
        "context-mode"
      ]
    }
  },
  "plugin": [
    "opencode-gemini-auth",
    "yet-another-opencode-cursor-auth@latest",
    "opencode-openai-codex-auth",
    "cursor-acp",
    "context-mode"
  ],
